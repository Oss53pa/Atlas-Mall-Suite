VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# La cle Claude est saisie par l'utilisateur dans l'UI (Settings > Cle API)
# Elle est transmise uniquement via header x-client-key vers la Edge Function
# Elle n'apparait JAMAIS dans le code source

# Monitoring Sentry (optionnel en dev, OBLIGATOIRE en production)
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0-rc.1

# Webhook feedback des rapports HTML (URL publique Edge Function)
VITE_REPORT_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/report-webhook

# Analytics / consent mode
VITE_ANALYTICS_ENABLED=false
