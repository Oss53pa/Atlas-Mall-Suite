{
  "name": "atlas-mall-suite",
  "description": "Plateforme SaaS de pilotage pour centres commerciaux — cartographie 2D/3D/AR, visites guidées, rapports HTML interactifs, IA PROPH3T",
  "private": true,
  "version": "1.0.0-rc.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=9999",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "build:analyze": "vite build --mode analyze",
    "precommit": "npm run typecheck && npm run lint:ci",
    "prepare-release": "npm run typecheck && npm run lint:ci && npm test && npm run build",
    "migrate:plan": "node --import tsx scripts/migrate-plan.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@mlightcad/libredwg-web": "^0.6.7",
    "@react-three/fiber": "^8.18.0",
    "@react-three/xr": "^5.7.1",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.94.5",
    "@types/three": "^0.183.1",
    "@use-gesture/react": "^10.3.1",
    "comlink": "^4.4.2",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "docx": "^9.6.1",
    "dwg2dxf": "^2.0.3",
    "dxf-parser": "^1.1.2",
    "dxf-viewer": "^1.0.47",
    "exceljs": "^4.4.0",
    "hotkeys-js": "^4.0.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "opentype.js": "^1.3.4",
    "pathfinding": "^0.4.18",
    "pdfjs-dist": "^5.5.207",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "simple-statistics": "^7.8.9",
    "svg2pdf.js": "^2.7.0",
    "three": "^0.183.2",
    "uuid": "^13.0.0",
    "web-ifc": "^0.0.77",
    "web-ifc-three": "^0.0.126",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^4.1.1"
  }
}
